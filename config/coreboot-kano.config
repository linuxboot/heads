CONFIG_LOCALVERSION="MrChromebox-26.03"
CONFIG_BOOTSPLASH_IMAGE=y
CONFIG_BOOTSPLASH_FILE="@BRAND_DIR@/bootsplash.jpg"
CONFIG_VENDOR_GOOGLE=y
CONFIG_MAINBOARD_PART_NUMBER="Omnigul"
CONFIG_CBFS_SIZE=0xBE0000
CONFIG_INTEL_GMA_VBT_FILE="3rdparty/blobs/mainboard/google/brya/brya/omnigul/vbt.bin"
CONFIG_DISABLE_HECI1_AT_PRE_BOOT=y
CONFIG_IFD_BIN_PATH="3rdparty/blobs/mainboard/google/brya/brya/omnigul/flashdescriptor.bin"
CONFIG_ME_BIN_PATH="3rdparty/blobs/mainboard/google/brya/brya/omnigul/me.bin"
CONFIG_BOARD_GOOGLE_KANO=y
CONFIG_USE_LEGACY_8254_TIMER=y
CONFIG_HAVE_IFD_BIN=y
CONFIG_TPM_MEASURED_BOOT=y
CONFIG_POWER_STATE_OFF_AFTER_FAILURE=y
CONFIG_HAVE_ME_BIN=y
CONFIG_BOOTSPLASH=y
# CONFIG_RESOURCE_ALLOCATION_TOP_DOWN is not set
CONFIG_SMMSTORE=y
CONFIG_SMMSTORE_V2=y
CONFIG_SMMSTORE_SIZE=0x40000
CONFIG_TPM_PPI=y
CONFIG_PAYLOAD_LINUX=y
CONFIG_PAYLOAD_FILE="@BOARD_BUILD_DIR@/bzImage"
CONFIG_LINUX_INITRD="@BOARD_BUILD_DIR@/initrd.cpio.xz"
