# WARNING: This system remains perpetually vulnerable to Spectre v2 (CVE-2017-5715). Mitigations and microcode updates previously applied are now known to be ineffective due to QSB-107 and related CVEs. If Spectre v2 is a concern in your threat model, consider migrating to a platform with ongoing microcode support.
# Inherit the rest from the base T440p config.
include $(pwd)/boards/UNTESTED_t440p-maximized/UNTESTED_t440p-maximized.config

CONFIG_HOTPKEY=y
export CONFIG_AUTO_BOOT_TIMEOUT=5

export CONFIG_BOARD_NAME="ThinkPad T440p-hotp-maximized"
