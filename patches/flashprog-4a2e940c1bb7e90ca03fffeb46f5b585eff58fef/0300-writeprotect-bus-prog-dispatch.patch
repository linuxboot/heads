+/*
+ * Dispatch register reads/writes through the opaque master's callbacks when
+ * on a BUS_PROG programmer (e.g. ICH hwseq), falling back to SPI otherwise.
+ */
+static int wp_read_register(const struct flashctx *flash, enum flash_reg reg, uint8_t *value)
+{
+	if ((flash->chip->bustype & BUS_PROG) && flash->mst.opaque->read_register)
+		return flash->mst.opaque->read_register(flash, reg, value);
+	return spi_read_register(flash, reg, value);
+}
+
+static int wp_write_register(const struct flashctx *flash, enum flash_reg reg, uint8_t value)
+{
+	if ((flash->chip->bustype & BUS_PROG) && flash->mst.opaque->write_register)
+		return flash->mst.opaque->write_register(flash, reg, value);
+	return spi_write_register(flash, reg, value, default_wrsr_target(flash));
+}
 
