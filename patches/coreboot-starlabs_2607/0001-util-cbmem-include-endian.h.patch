 1 file changed, 1 insertion(+)

diff --git a/util/cbmem/cbmem.c b/util/cbmem/cbmem.c
index 018ea871f9..f0afc5601d 100644
--- a/util/cbmem/cbmem.c
+++ b/util/cbmem/cbmem.c
@@ -12,6 +12,7 @@
 #include <fcntl.h>
 #include <ctype.h>
