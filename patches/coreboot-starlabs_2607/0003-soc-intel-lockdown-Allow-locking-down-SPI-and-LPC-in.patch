+++ b/src/soc/intel/common/pch/include/intelpch/lockdown.h
@@ -25,4 +25,7 @@ int get_lockdown_config(void);
  */
 void soc_lockdown_config(int chipset_lockdown);
 
+void fast_spi_lockdown_bios(int chipset_lockdown);
