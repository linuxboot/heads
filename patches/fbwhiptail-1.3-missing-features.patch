+/*
+ * Scroll the textbox by delta lines (positive = down, negative = up).
+ * Returns 1 if the view changed (redraw needed), 0 otherwise.
+ */
+static int scroll_text(Menu *menu, int delta)
+{
+  int new_start = menu->text.start_line + delta;
+  if (new_start < 0) new_start = 0;
+  if (new_start >= menu->text.nlines) new_start = menu->text.nlines - 1;
+  if (new_start == menu->text.start_line) return 0;
+  menu->text.start_line = new_start;
+  menu_refresh_text(menu);
+  /* Frame must be rebuilt since text height may change */
+  if (menu->frame) {
+    cairo_hires_buffer_destroy(menu->frame);
+    menu->frame = NULL;
+  }
+  return 1;
+}
