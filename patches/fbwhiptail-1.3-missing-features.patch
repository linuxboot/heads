+static void update_list_item_display(Menu *menu, whiptail_args *args, int idx)
+{
+  CairoMenuItem *item = &menu->menu->items[idx];
+  char text[512];
+  const char *marker;
+
+  if (args->mode == MODE_CHECKLIST)
+    marker = args->items[idx].status ? "[X]" : "[ ]";
+  else
+    marker = args->items[idx].status ? "[*]" : "[ ]";
+
+  if (args->notags) {
+    snprintf(text, sizeof(text), "%s %s", marker, args->items[idx].item);
+  } else if (args->noitem) {
+    snprintf(text, sizeof(text), "%s %s", marker, args->items[idx].tag);
+  } else {
+    snprintf(text, sizeof(text), "%s %s - %s",
+             marker, args->items[idx].tag, args->items[idx].item);
+  }
+
+  if (item->text) free(item->text);
+  item->text = strdup(text);
+}
