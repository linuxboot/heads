+/*
+ * Toggle or set the current item for checklist/radiolist.
+ * For radiolist: select only the current item.
+ * For checklist: toggle the current item.
+ * Updates display text for affected items.
+ */
+static void toggle_list_item(Menu *menu, whiptail_args *args)
+{
+  int sel = menu->menu->selection;
+
+  if (args->mode == MODE_CHECKLIST) {
+    args->items[sel].status = !args->items[sel].status;
+    update_list_item_display(menu, args, sel);
+  } else { /* MODE_RADIOLIST */
+    int i;
+    for (i = 0; i < args->num_items; i++)
+      args->items[i].status = 0;
+    args->items[sel].status = 1;
+    for (i = 0; i < args->num_items; i++)
+      update_list_item_display(menu, args, i);
+  }
+}
